<?xml version="1.0" encoding="UTF-8"?>
<libraries checkVersion="update || all">
	<if cond="update || all">
		<print pretty="true">Preparing installation...</print>

		<!-- Hxcpp & OpenFL & Lime (Required for Flixel) -->
		<git name="hxcpp" url="https://github.com/ShadowEngineTeam/hxcpp"/>
		<git name="openfl" url="https://github.com/ShadowEngineTeam/openfl" skipDeps="true"/>
		<git name="lime" url="https://github.com/ShadowEngineTeam/lime" skipDeps="true"/>

		<!-- Flixel -->
		<git name="flixel" url="https://github.com/ShadowEngineTeam/flixel" skipDeps="true"/>
		<git name="flixel-addons" url="https://github.com/FunkinCrew/flixel-addons" ref="dev" skipDeps="true"/>

		<!-- CNE Core Libraries -->
		<git name="flixel-animate" url="https://github.com/CodenameCrew/cne-flixel-animate" skipDeps="true"/>
		<git name="hscript-improved" url="https://github.com/ShadowEngineTeam/ShadowScript" ref="codename-dev"/>
		<git name="away3d" url="https://github.com/CodenameCrew/away3d" skipDeps="true"/>

		<!-- Other Libraries -->
		<git name="hxdiscord_rpc" url="https://github.com/CodenameCrew/cne-hxdiscord_rpc" skipDeps="true"/>
		<git name="hxvlc" url="https://github.com/CodenameCrew/cne-hxvlc" skipDeps="true"/>
		<lib name="funkin-modchart" skipDeps="true"/>
		<lib name="hxcpp-debug-server"/>
		<lib name="format"/>
		<lib name="markdown"/>
		<lib name="nape-haxe4"/>
	</if>
</libraries>
